      "conversation_starters": { "items": { "type": "string" }, "type": "array", "title": "Conversation Starters" },
      "provider": { "type": "string", "title": "Provider" },
      "model": { "type": "string", "title": "Model" },
      "labels": { "type": "object", "title": "Labels" }
